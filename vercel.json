{
  "rewrites": [
    { "source": "/", "destination": "/login.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/novo", "destination": "/dashboard.html" },
    { "source": "/novo-ae", "destination": "/ae.html" },
    { "source": "/novo-bdr", "destination": "/bdr.html" },
    { "source": "/novo-bdr/no-show", "destination": "/bdr-no-show.html" },
    { "source": "/novo-bdr/workload", "destination": "/bdr-workload.html" },
    { "source": "/dashboard/bdr/workload", "destination": "/bdr-workload.html" },
    { "source": "/novo-bdr/list-attack", "destination": "/bdr-list-attack.html" },
    { "source": "/novo-bdr/treble", "destination": "/bdr-treble.html" },
    { "source": "/dashboard/bdr/no-show", "destination": "/bdr-no-show.html" },
    { "source": "/dashboard/bdr/list-attack", "destination": "/bdr-list-attack.html" },
    { "source": "/dashboard/bdr/treble", "destination": "/bdr-treble.html" },
    { "source": "/novo-bdr-no-show", "destination": "/bdr-no-show.html" },
    { "source": "/novo-bdr-list-attack", "destination": "/bdr-list-attack.html" },
    { "source": "/novo-bdr-treble", "destination": "/bdr-treble.html" },
    { "source": "/novo-board", "destination": "/board.html" },
    { "source": "/novo-48h", "destination": "/48h.html" },
    { "source": "/novo-cs", "destination": "/cs.html" },
    { "source": "/novo-cotacao", "destination": "/cotacao.html" },
    { "source": "/forecast", "destination": "/forecast.html" },
    { "source": "/forecast-delta", "destination": "/forecast-delta.html" },
    { "source": "/forecast-overall", "destination": "/forecast-stage.html" },
    { "source": "/forecast-mql", "destination": "/forecast-stage.html" },
    { "source": "/forecast-diagnostico", "destination": "/forecast-stage.html" },
    { "source": "/forecast-cotacao", "destination": "/forecast-stage.html" },
    { "source": "/forecast-consultoria", "destination": "/forecast-stage.html" },
    { "source": "/forecast-negociacao", "destination": "/forecast-stage.html" },
    { "source": "/forecast-ganho", "destination": "/forecast-stage.html" },
    { "source": "/forecast-bid", "destination": "/forecast-stage.html" }
  ],
  "crons": [
    {
      "path":     "/api/snapshot",
      "schedule": "59 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/electron-shim.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  }
}
